---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found | Just Enuff Cabaret"
  description="The page you're looking for doesn't exist. Head back to Just Enuff Cabaret, Rockford IL's premier gentlemen's club."
>
  <div class="page-hero" style="min-height:60vh;display:flex;flex-direction:column;justify-content:center;">
    <span class="eyebrow">404</span>
    <h1 class="page-title">This Page Left the <em>Stage</em></h1>
    <div class="rule"></div>
    <p class="lead">The page you're looking for doesn't exist, but the party's still on.</p>
    <div class="hero-btns" style="margin-top:2rem;justify-content:center;display:flex;gap:1rem;flex-wrap:wrap;">
      <a class="btn btn-red" href="/">Back to Home</a>
      <a class="btn btn-gold" href="/events">See Events</a>
    </div>
  </div>
</Base>
