---
import Base from '../layouts/Base.astro';
import { business } from '../data/site.js';

// The form posts to /api/apply (a Cloudflare Pages Function in /functions/api/apply.js)
// which emails applications via Microsoft Graph. Note: the form only works on the
// deployed Cloudflare site, not in local `npm run dev`.
---

<Base
  title="Apply | Entertainer Auditions & Staff Positions | Just Enuff Cabaret Rockford"
  description="Apply to Just Enuff Cabaret in Rockford, IL. Entertainer auditions plus positions for bartenders, cocktail servers, hosts, and security. Apply online. 21+ with valid ID."
>
  <div class="page-hero">
    <span class="eyebrow">Entertainers &amp; Staff</span>
    <h1 class="page-title">Apply to <em>Just Enuff</em></h1>
    <div class="rule"></div>
    <p class="lead">
      Entertainers audition year-round, and we're always looking for bartenders, cocktail
      servers, hosts, and door staff. Fill out the application below or email
      <a href={`mailto:${business.email}`} style="color:var(--gold);"> {business.email}</a>.
    </p>
  </div>

  <section>
    <div class="inner-sm">
      <form class="card" id="applyForm" novalidate>
        <div class="form-grid">
          <div class="form-field full">
            <label for="position">Desired Position *</label>
            <select id="position" name="position" required>
              <option value="">Select a position</option>
              <option>Entertainer / Dancer</option>
              <option>Bartender</option>
              <option>Cocktail Server</option>
              <option>Host</option>
              <option>Door Staff / Security</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-field">
            <label for="firstName">First Name *</label>
            <input id="firstName" name="firstName" type="text" autocomplete="given-name" required />
          </div>
          <div class="form-field">
            <label for="lastName">Last Name *</label>
            <input id="lastName" name="lastName" type="text" autocomplete="family-name" required />
          </div>
          <div class="form-field">
            <label for="phone">Phone *</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" inputmode="numeric"
              placeholder="(815) 555-1234" maxlength="14" pattern="\(\d{3}\) \d{3}-\d{4}" required />
          </div>
          <div class="form-field">
            <label for="email">Email *</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form-field">
            <label for="dob">Date of Birth *</label>
            <input id="dob" name="dob" type="date" min="1920-01-01" required />
          </div>
          <div class="form-field">
            <label for="city">City *</label>
            <input id="city" name="city" type="text" autocomplete="address-level2" required />
          </div>
          <div class="form-field">
            <label for="state">State *</label>
            <select id="state" name="state" autocomplete="address-level1" required>
              <option value="">Select state</option>
              <option>AL</option>
              <option>AK</option>
              <option>AZ</option>
              <option>AR</option>
              <option>CA</option>
              <option>CO</option>
              <option>CT</option>
              <option>DE</option>
              <option>FL</option>
              <option>GA</option>
              <option>HI</option>
              <option>ID</option>
              <option>IL</option>
              <option>IN</option>
              <option>IA</option>
              <option>KS</option>
              <option>KY</option>
              <option>LA</option>
              <option>ME</option>
              <option>MD</option>
              <option>MA</option>
              <option>MI</option>
              <option>MN</option>
              <option>MS</option>
              <option>MO</option>
              <option>MT</option>
              <option>NE</option>
              <option>NV</option>
              <option>NH</option>
              <option>NJ</option>
              <option>NM</option>
              <option>NY</option>
              <option>NC</option>
              <option>ND</option>
              <option>OH</option>
              <option>OK</option>
              <option>OR</option>
              <option>PA</option>
              <option>RI</option>
              <option>SC</option>
              <option>SD</option>
              <option>TN</option>
              <option>TX</option>
              <option>UT</option>
              <option>VT</option>
              <option>VA</option>
              <option>WA</option>
              <option>WV</option>
              <option>WI</option>
              <option>WY</option>
              <option>DC</option>
            </select>
          </div>
          <div class="form-field full">
            <label for="experience">Do you have any prior experience?</label>
            <select id="experience" name="experience">
              <option value="">Select one</option>
              <option>Yes, I have experience</option>
              <option>No, this would be my first time</option>
            </select>
          </div>
          <div class="form-field full">
            <label for="about">Tell Us About Yourself</label>
            <textarea id="about" name="about" rows="5"></textarea>
          </div>
          <div class="form-field full">
            <label for="photo">Upload a Recent Photo *</label>
            <input id="photo" name="photoFile" type="file" accept="image/*" required />
            <span id="photoNote" style="font-size:0.85rem;color:var(--grey);">
              A clear, recent photo of yourself. Large photos are resized automatically.
            </span>
          </div>
          <!-- Honeypot: hidden from humans, bots fill it and get silently dropped -->
          <div class="form-field full" style="position:absolute;left:-9999px;" aria-hidden="true">
            <label for="company">Company</label>
            <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>
        </div>
        <p class="form-fineprint">
          All applicants must be 21+ with valid government-issued ID. Submitting this form does not
          guarantee a position; management will contact qualified candidates. Having trouble with the
          photo upload? Email your application and photo to
          <a href={`mailto:${business.email}`} style="color:var(--gold);"> {business.email}</a> instead.
        </p>
        <div style="margin-top:1.4rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
          <button type="submit" class="btn btn-red" id="applyBtn">Submit Application</button>
          <span id="applyStatus" role="status" style="color:var(--grey);font-style:italic;"></span>
        </div>
      </form>

      <div class="card" id="applyThanks" style="display:none;text-align:center;padding:3rem 2rem;">
        <h2 style="font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.6rem;margin-bottom:0.8rem;">
          Application Received!
        </h2>
        <p style="color:var(--grey);max-width:520px;margin:0 auto;">
          Thanks for applying to Just Enuff Cabaret. Management will contact qualified
          candidates.
        </p>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('applyForm');
    const btn = document.getElementById('applyBtn');
    const status = document.getElementById('applyStatus');

    // Phone: digits only, auto-formatted as (XXX) XXX-XXXX
    const phoneEl = document.getElementById('phone');
    phoneEl.addEventListener('input', () => {
      const d = phoneEl.value.replace(/\D/g, '').slice(0, 10);
      let out = d;
      if (d.length > 6) out = `(${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6)}`;
      else if (d.length > 3) out = `(${d.slice(0, 3)}) ${d.slice(3)}`;
      else if (d.length > 0) out = `(${d}`;
      phoneEl.value = out;
      phoneEl.setCustomValidity(d.length === 10 ? '' : 'Please enter a 10-digit phone number.');
    });

    // Date of birth: must be a real date at least 21 years ago
    const dobEl = document.getElementById('dob');
    const cutoff = new Date();
    cutoff.setFullYear(cutoff.getFullYear() - 21);
    dobEl.max = cutoff.toISOString().slice(0, 10);
    dobEl.addEventListener('change', () => {
      dobEl.setCustomValidity(
        dobEl.value && dobEl.value > dobEl.max ? 'All applicants must be 21 or older.' : ''
      );
    });

    // Shrink big phone photos in the browser so they fit in an email attachment
    async function preparePhoto(file) {
      if (!file || file.size === 0) return null;
      try {
        const bitmap = await createImageBitmap(file);
        const MAX = 1600;
        const scale = Math.min(1, MAX / Math.max(bitmap.width, bitmap.height));
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(bitmap.width * scale);
        canvas.height = Math.round(bitmap.height * scale);
        canvas.getContext('2d').drawImage(bitmap, 0, 0, canvas.width, canvas.height);
        const blob = await new Promise((r) => canvas.toBlob(r, 'image/jpeg', 0.85));
        const dataUrl = await new Promise((resolve, reject) => {
          const fr = new FileReader();
          fr.onload = () => resolve(fr.result);
          fr.onerror = reject;
          fr.readAsDataURL(blob);
        });
        return { name: 'applicant-photo.jpg', type: 'image/jpeg', data: dataUrl.split(',')[1] };
      } catch {
        // Browser couldn't read this image format; send as-is if it's small enough
        if (file.size <= 2.5 * 1024 * 1024) {
          const dataUrl = await new Promise((resolve, reject) => {
            const fr = new FileReader();
            fr.onload = () => resolve(fr.result);
            fr.onerror = reject;
            fr.readAsDataURL(file);
          });
          return { name: file.name, type: file.type || 'application/octet-stream', data: dataUrl.split(',')[1] };
        }
        throw new Error('photo-too-large');
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      btn.disabled = true;
      status.textContent = 'Sending…';

      const data = Object.fromEntries(new FormData(form).entries());
      delete data.photoFile;
      try {
        const photoInput = document.getElementById('photo');
        const photo = await preparePhoto(photoInput.files[0]);
        if (photo) {
          data.photoName = photo.name;
          data.photoType = photo.type;
          data.photoData = photo.data;
        }
        if (!photo) {
          status.textContent = 'Please upload a recent photo of yourself.';
          btn.disabled = false;
          return;
        }
      } catch {
        status.textContent = 'That photo could not be processed. Please try a different photo.';
        btn.disabled = false;
        return;
      }
      try {
        const res = await fetch('/api/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (res.ok && result.ok) {
          form.style.display = 'none';
          document.getElementById('applyThanks').style.display = '';
        } else {
          status.textContent = result.error || 'Something went wrong. Please email us instead.';
          btn.disabled = false;
        }
      } catch {
        status.textContent = 'Connection problem. Please try again or email us.';
        btn.disabled = false;
      }
    });
  </script>
</Base>
