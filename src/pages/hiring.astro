---
import Base from '../layouts/Base.astro';
import { business } from '../data/site.js';

// ============================================================
// MICROSOFT FORMS SETUP
// 1. Go to https://forms.office.com and create the application form
// 2. Collect responses → set "Anyone can respond"
// 3. Click Share → the "</>" (embed) icon → copy the URL inside src="..."
// 4. Paste it below, replacing the PASTE_EMBED_URL_HERE placeholder
// ============================================================
const MS_FORM_EMBED_URL = 'PASTE_EMBED_URL_HERE';
const formReady = MS_FORM_EMBED_URL.startsWith('https://');
---

<Base
  title="Now Hiring Dancers, Bartenders & Staff | Just Enuff Cabaret Rockford IL"
  description="Join the team at Just Enuff Cabaret in Rockford, IL. Now hiring entertainers/dancers, bartenders, cocktail servers, security, and DJs. Apply online. 21+ with valid ID."
>
  <div class="page-hero">
    <span class="eyebrow">Join Our Team</span>
    <h1 class="page-title">Now <em>Hiring</em></h1>
    <div class="rule"></div>
    <p class="lead">
      We're always looking for entertainers, bartenders, cocktail servers, door staff,
      and DJs. Fill out the application below or email
      <a href={`mailto:${business.email}`} style="color:var(--gold);"> {business.email}</a>.
    </p>
  </div>

  <section>
    <div class="inner-sm">
      {formReady ? (
        <div class="card" style="padding:0.6rem;">
          <iframe
            src={MS_FORM_EMBED_URL}
            title="Just Enuff Cabaret job application form"
            style="width:100%;height:1400px;border:none;background:transparent;"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="card" style="text-align:center;padding:3rem 2rem;">
          <h2 style="font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.6rem;margin-bottom:0.8rem;">
            Application Form Coming Soon
          </h2>
          <p style="color:var(--grey);max-width:520px;margin:0 auto 1.6rem;">
            In the meantime, send us your name, phone number, desired position, and a recent
            photo by email. We'd love to hear from you.
          </p>
          <a class="btn btn-red" href={`mailto:${business.email}?subject=Job%20Application`}>Email Your Application</a>
        </div>
      )}
      <p class="form-fineprint" style="text-align:center;">
        A recent photo helps your application. Email one to
        <a href={`mailto:${business.email}`} style="color:var(--gold);"> {business.email}</a>.
        All applicants must be 21+ with valid government-issued ID. Submitting an application does
        not guarantee employment; management will contact qualified candidates.
      </p>
    </div>
  </section>
</Base>
