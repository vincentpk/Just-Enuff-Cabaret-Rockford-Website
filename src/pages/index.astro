---
import Base from '../layouts/Base.astro';
import PhotoSlot from '../components/PhotoSlot.astro';
import { business, dancers, packages, serviceAreas } from '../data/site.js';

const featuredDancers = dancers.slice(0, 3);
const featuredPackages = packages.slice(0, 3);
---

<Base
  title="Just Enuff Cabaret | Strip Club & Gentlemen's Club in Rockford, IL"
  description="Rockford's premier strip club & gentlemen's club at 1609 S Alpine Rd. VIP bottle service, beautiful entertainers, full bar & kitchen. Open 7 nights, 4 PM–2 AM. Minutes from I-90 and an easy drive from Chicago, Elgin, Lake Geneva, Madison & Milwaukee."
>
  <div class="home-hero">
    <div class="curtain-l"></div>
    <div class="curtain-r"></div>
    <div class="stage-light"></div>
    <div class="hero-content">
      <img class="hero-logo" src="/images/logo.png" alt="Just Enuff Cabaret, premier gentlemen's club and strip club in Rockford, Illinois" width="360" height="310" />
      <h1 class="hero-tag">Where the Night Comes Alive</h1>
      <p class="hero-sub">Premier Gentlemen's Club · Rockford, IL</p>
      <div class="hero-btns">
        <a class="btn btn-red" href="/dancers">Meet the Entertainers</a>
        <a class="btn btn-gold" href="/vip">View VIP Packages</a>
      </div>
    </div>
  </div>

  <section>
    <div class="inner-sm" style="text-align:center;">
      <span class="eyebrow">Welcome to Just Enuff</span>
      <h2 class="section-title">Rockford's Premier <em>Gentlemen's Club</em></h2>
      <div class="rule"></div>
      <p class="lead">
        Just Enuff Cabaret is Rockford, Illinois' destination for upscale adult nightlife:
        world-class entertainers, premium VIP bottle service, a full late-night kitchen, and an
        unforgettable atmosphere. Located at {business.address.street}, minutes from I-90 and I-39,
        we're an easy drive from Chicago, Elgin, Aurora, Beloit, Janesville, Lake Geneva, Madison,
        and Milwaukee. Open 7 nights a week, 4 PM to 2 AM.
      </p>
      <div class="hero-btns" style="margin-top:2rem;">
        <a class="btn btn-gold" href="/club">Explore the Club</a>
      </div>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="inner">
      <div class="section-header">
        <span class="eyebrow">Featured Artists</span>
        <h2 class="section-title">Meet the <em>Entertainers</em></h2>
        <div class="rule"></div>
      </div>
      <div class="grid-3">
        {featuredDancers.map((d) => (
          <a href="/dancers" class="card" style="padding:0.9rem;">
            <PhotoSlot image={d.image} alt={`${d.name}, entertainer at Just Enuff Cabaret, Rockford IL`} />
            <div class="card-name">{d.name}</div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.2rem;">
        <a class="btn btn-red" href="/dancers">View All Dancers</a>
      </div>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="inner">
      <div class="section-header">
        <span class="eyebrow">VIP Experience</span>
        <h2 class="section-title">Bottle Service &amp; <em>VIP Packages</em></h2>
        <div class="rule"></div>
      </div>
      <div class="grid-3">
        {featuredPackages.map((p) => (
          <div class={`card pkg ${p.featured ? 'featured' : ''}`}>
            {p.featured && <div class="badge">Most Popular</div>}
            <div>
              <div class="pkg-tier">{p.tier}</div>
              <div class="pkg-name">{p.name}</div>
            </div>
            <div class="pkg-price">{p.price} <small>{p.unit}</small></div>
            <ul>{p.perks.slice(0, 4).map((perk) => <li>{perk}</li>)}</ul>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.2rem;">
        <a class="btn btn-gold" href="/vip">See All Packages &amp; Reserve</a>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="inner-sm">
      <h2>Worth the Drive From Anywhere</h2>
      <p>
        Guests join us every week from across northern Illinois and southern Wisconsin.
      </p>
      <div class="grid-4" style="text-align:left;">
        {serviceAreas.map((a) => (
          <div>
            <div style="font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.05rem;">{a.city}</div>
            <div style="font-family:'Bebas Neue',sans-serif;letter-spacing:0.12em;color:var(--grey);font-size:0.82rem;">{a.drive}</div>
          </div>
        ))}
      </div>
      <div style="margin-top:2rem;">
        <a class="btn btn-red" href="/contact">Directions &amp; Parking</a>
      </div>
    </div>
  </section>

  <section>
    <div class="inner-sm" style="text-align:center;">
      <span class="eyebrow">Tonight</span>
      <h2 class="section-title">Open 7 Nights · <em>4 PM – 2 AM</em></h2>
      <div class="rule"></div>
      <p class="lead">
        Walk-ins welcome. For VIP booths, bottle service, bachelor parties, and birthdays,
        call <a href={business.phoneHref} style="color:var(--gold);">{business.phone}</a> to reserve.
      </p>
      <div class="hero-btns" style="margin-top:2rem;">
        <a class="btn btn-red" href={business.phoneHref}>Call to Book</a>
        <a class="btn btn-gold" href="/events">See Upcoming Events</a>
      </div>
    </div>
  </section>
</Base>
