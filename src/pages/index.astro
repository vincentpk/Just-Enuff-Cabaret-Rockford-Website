---
import Base from '../layouts/Base.astro';
import PhotoSlot from '../components/PhotoSlot.astro';
import { business, dancers, packages, serviceAreas, happyHour } from '../data/site.js';

const featuredDancers = dancers.slice(0, 3);
const featuredPackages = packages.slice(0, 3);
---

<Base
  title="Just Enuff Cabaret | Strip Club & Gentlemen's Club in Rockford, IL"
  description={`Rockford's premier strip club & gentlemen's club at 1609 S Alpine Rd. VIP bottle service, entertainers & late-night kitchen. Open 7 nights, 4 PM-2 AM.`}
>
  <div class="home-hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/videos/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-veil"></div>
    <div class="stage-light"></div>
    <div class="hero-content">
      <img class="hero-logo" src="/images/logo.png" alt="Just Enuff Cabaret, premier gentlemen's club and strip club in Rockford, Illinois" width="360" height="310" />
      <h1 class="hero-tag">Where the Night Comes Alive</h1>
      <p class="hero-sub">Premier Gentlemen's Club · Rockford, IL</p>
      <div class="hero-btns">
        <a class="btn btn-red" href="/dancers">Meet the Entertainers</a>
        <a class="btn btn-gold" href="/vip">View VIP Packages</a>
      </div>
    </div>
  </div>

  {happyHour && (
    <section style="padding:2.6rem 1.2rem;border-top:1px solid var(--gold);border-bottom:1px solid var(--gold);background:linear-gradient(180deg,rgba(200,16,46,0.12),rgba(201,168,76,0.06));">
      <div class="inner" style="text-align:center;">
        <span class="eyebrow" style="color:var(--gold-light);">Weekday Happy Hour</span>
        <h2 class="section-title" style="margin:0.3rem 0 0.2rem;">{happyHour.days} · <em style="white-space:nowrap;">{happyHour.time}</em></h2>
        <div class="rule"></div>
        <div class="grid-4" style="margin-top:1.6rem;">
          {happyHour.items.map((it) => (
            <div>
              <div style="font-family:'Bebas Neue',sans-serif;letter-spacing:0.04em;color:var(--gold-light);font-size:2.4rem;line-height:1;">{it.price}</div>
              <div style="font-family:'Playfair Display',serif;color:var(--cream);font-size:1.05rem;margin-top:0.3rem;">{it.name}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section>
    <div class="inner-sm" style="text-align:center;">
      <span class="eyebrow">Welcome to Just Enuff</span>
      <h2 class="section-title">Rockford's Premier <em>Gentlemen's Club</em></h2>
      <div class="rule"></div>
      <p class="lead">
        Just Enuff Cabaret is Rockford, Illinois' destination for upscale adult nightlife:
        world-class entertainers, premium VIP bottle service, a full late-night kitchen Friday
        through Sunday, and an
        unforgettable atmosphere. Located at {business.address.street}, minutes from I-90 and I-39,
        we're an easy drive from Chicago, Elgin, Aurora, Beloit, Janesville, Lake Geneva, Madison,
        and Milwaukee. Open 7 nights a week, 4 PM to 2 AM.
      </p>
      <div class="hero-btns" style="margin-top:2rem;">
        <a class="btn btn-gold" href="/club">Explore the Club</a>
      </div>
    </div>
  </section>

  {business.award && (
    <section style="padding-top:0;">
      <div class="inner-sm">
        <div style="border:1px solid var(--gold);border-radius:6px;padding:2.4rem 1.6rem;text-align:center;background:linear-gradient(180deg,rgba(201,168,76,0.07),transparent);">
          <img src="/images/ed-awards-nominee.png" alt="The ED's 2026 Awards Nominee badge" width="900" height="516" style="max-width:340px;width:80%;height:auto;margin:0 auto 1.2rem;display:block;" />
          <h2 class="section-title" style="margin-top:0.4rem;">Nominated: <em>Small Club of the Year</em></h2>
          <div class="rule"></div>
          <p class="lead" style="max-width:660px;margin:0 auto;">
            Just Enuff Cabaret is a {business.award.announcementUrl ? (
              <a href={business.award.announcementUrl} target="_blank" rel="noopener" style="color:var(--gold-light);">{business.award.label}</a>
            ) : business.award.label} for {business.award.category},
            recognized among the top clubs in the Midwest. Help us bring the title home to Rockford.
          </p>
          <div class="hero-btns" style="margin-top:1.8rem;">
            <a class="btn btn-gold" href={business.award.voteUrl} target="_blank" rel="noopener">Vote for Us</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section style="padding-top:0;">
    <div class="inner">
      <div class="section-header">
        <h2 class="section-title">Meet the <em>Entertainers</em></h2>
        <div class="rule"></div>
      </div>
      <div class="grid-3">
        {featuredDancers.map((d) => (
          <a href="/dancers" class="card" style="padding:0.9rem;">
            <PhotoSlot image={d.image} alt={`${d.name}, entertainer at Just Enuff Cabaret, Rockford IL`} />
            <div class="card-name">{d.name}</div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.2rem;">
        <a class="btn btn-red" href="/dancers">View All Dancers</a>
      </div>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="inner">
      <div class="section-header">
        <span class="eyebrow">VIP Experience</span>
        <h2 class="section-title">Bottle Service &amp; <em>VIP Packages</em></h2>
        <div class="rule"></div>
      </div>
      <div class="grid-3">
        {featuredPackages.map((p) => (
          <a href="/vip" class={`card pkg ${p.featured ? 'featured' : ''}`} aria-label={`${p.name}: see full details and reserve`}>
            {p.featured && <div class="badge">Most Popular</div>}
            <div>
              <div class="pkg-tier">{p.tier}</div>
              <div class="pkg-name">{p.name}</div>
            </div>
            <div class="pkg-price">{p.price} <small>{p.unit}</small></div>
            <ul>{p.perks.map((perk) => <li>{perk}</li>)}</ul>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.2rem;">
        <a class="btn btn-gold" href="/vip">See All Packages &amp; Reserve</a>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="inner-sm">
      <h2>Worth the Drive From Anywhere</h2>
      <p>
        Guests join us every week from across northern Illinois and southern Wisconsin.
      </p>
      <div class="grid-4" style="text-align:left;">
        {serviceAreas.map((a) => (
          <div>
            <div style="font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.05rem;">{a.city}</div>
            <div style="font-family:'Bebas Neue',sans-serif;letter-spacing:0.12em;color:var(--grey);font-size:0.82rem;">{a.drive}</div>
          </div>
        ))}
      </div>
      <div style="margin-top:2rem;">
        <a class="btn btn-red" href="/contact">Directions &amp; Parking</a>
      </div>
    </div>
  </section>

  <section>
    <div class="inner-sm" style="text-align:center;">
      <span class="eyebrow">Tonight</span>
      <h2 class="section-title">Open 7 Nights · <em style="white-space:nowrap;">4 PM – 2 AM</em></h2>
      <div class="rule"></div>
      <p class="lead">
        Walk-ins welcome. For VIP seating, bottle service, bachelor parties, and birthdays,
        call <a href={business.phoneHref} style="color:var(--gold);">{business.phone}</a> to reserve.
      </p>
      <div class="hero-btns" style="margin-top:2rem;">
        <a class="btn btn-red" href={business.phoneHref}>Call to Book</a>
        <a class="btn btn-gold" href="/events">See Upcoming Events</a>
      </div>
    </div>
  </section>

  <script>
    // iOS blocks video autoplay in Low Power Mode. Retry politely: on load,
    // on the first touch/click anywhere, and when returning to the tab.
    const v = document.querySelector('.hero-video');
    if (v) {
      v.muted = true;
      v.defaultMuted = true;
      const tryPlay = () => { v.play().catch(() => {}); };
      tryPlay();
      ['touchstart', 'click'].forEach((ev) =>
        document.addEventListener(ev, tryPlay, { once: true, passive: true })
      );
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) tryPlay();
      });
    }
  </script>
</Base>
