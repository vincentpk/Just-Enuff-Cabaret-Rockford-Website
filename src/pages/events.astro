---
import Base from '../layouts/Base.astro';
import PhotoSlot from '../components/PhotoSlot.astro';
import { business, events } from '../data/site.js';

// Build-time filter: drop events whose date has passed.
// (A small client-side script below also hides expired events, so nothing
// stale shows even if the site hasn't been redeployed in a while.)
const today = new Date().toISOString().slice(0, 10);
const upcoming = events
  .filter((e) => e.date && e.date >= today)
  .sort((a, b) => a.date.localeCompare(b.date));

function formatDate(iso) {
  return new Date(iso + 'T12:00:00').toLocaleDateString('en-US', {
    weekday: 'long', month: 'long', day: 'numeric'
  });
}

// SEO: schema.org Event listings for Google event search results
const eventSchemas = upcoming.map((e) => ({
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: e.title,
  description: e.desc,
  startDate: e.date,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  ...(e.image ? { image: new URL(e.image, Astro.site).href } : {}),
  location: {
    '@type': 'NightClub',
    name: business.name,
    address: {
      '@type': 'PostalAddress',
      streetAddress: business.address.street,
      addressLocality: business.address.city,
      addressRegion: business.address.state,
      postalCode: business.address.zip,
      addressCountry: 'US'
    }
  },
  organizer: { '@type': 'Organization', name: business.name, url: Astro.site?.href }
}));
---

<Base
  title="Events & Party Nights | Just Enuff Cabaret, Rockford IL Nightlife"
  description="Upcoming events, theme nights & parties at Just Enuff Cabaret in Rockford, IL. Bachelor parties, birthdays & special events 7 nights a week. Check the latest flyers or call (815) 399-4600."
  schema={eventSchemas}
>
  <div class="page-hero">
    <span class="eyebrow">What's On</span>
    <h1 class="page-title">Upcoming <em>Events</em></h1>
    <div class="rule"></div>
    <p class="lead">
      Theme nights, special guests, holiday parties, and more. There's always something
      happening at Just Enuff Cabaret. Check back often or follow us on social media.
    </p>
  </div>

  <section>
    <div class="inner">
      {upcoming.length > 0 ? (
        <div class="grid-3" id="eventGrid">
          {upcoming.map((e) => (
            <div class="card" style="padding:0.9rem;" data-event-date={e.date}>
              <PhotoSlot image={e.image} alt={`${e.title} at Just Enuff Cabaret, Rockford IL, ${formatDate(e.date)}`} label="Flyer Coming Soon" />
              <div class="card-name">
                {e.title}
                <div style="font-size:0.95rem;color:var(--gold-light);font-family:'Bebas Neue',sans-serif;letter-spacing:0.15em;margin-top:0.2rem;">
                  {formatDate(e.date)}
                </div>
                {e.desc && (
                  <p style="font-size:1rem;color:var(--grey);font-family:'Cormorant Garamond',serif;margin-top:0.6rem;line-height:1.5;text-align:left;">
                    {e.desc}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : null}
      <div id="noEvents" class="card" style={`text-align:center;padding:3rem 2rem;${upcoming.length > 0 ? 'display:none;' : ''}`}>
        <h2 style="font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.5rem;margin-bottom:0.6rem;">New Events Coming Soon</h2>
        <p style="color:var(--grey);max-width:480px;margin:0 auto;">
          We're always planning the next big night. Follow us on social media or call
          <a href={business.phoneHref} style="color:var(--gold);"> {business.phone}</a> to hear what's next.
        </p>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="inner-sm">
      <h2>Planning a Bachelor Party or Birthday?</h2>
      <p>Reserved sections, bottle service, and celebration extras. We'll make it a night to remember.</p>
      <a class="btn btn-red" href="/vip">Group Packages</a>
      <a class="btn btn-gold" href={business.phoneHref} style="margin-left:0.8rem;">Call {business.phone}</a>
    </div>
  </section>

  <script>
    // Hide any event whose date has passed, even if the site hasn't been
    // rebuilt since. Runs in the visitor's browser.
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    let visible = 0;
    document.querySelectorAll('[data-event-date]').forEach((card) => {
      const d = new Date(card.dataset.eventDate + 'T23:59:59');
      if (d < today) card.remove();
      else visible++;
    });
    if (visible === 0) {
      const empty = document.getElementById('noEvents');
      if (empty) empty.style.display = '';
      const grid = document.getElementById('eventGrid');
      if (grid) grid.remove();
    }
  </script>
</Base>
