---
import Base from '../layouts/Base.astro';
import { business, bottleMenu, foodMenu, happyHour } from '../data/site.js';
---

<Base
  title="Menu & Bottle Service | Just Enuff Cabaret, Rockford IL"
  description={`Bottle service at Just Enuff Cabaret, Rockford IL: Veuve, Dom Perignon, Ace of Spades & Clase Azul. Late-night wings, pizza & cheesesteaks.`}
>
  <div class="page-hero">
    <span class="eyebrow">Dining &amp; Drinks</span>
    <h1 class="page-title">Menu &amp; <em>Bottle Service</em></h1>
    <div class="rule"></div>
    <p class="lead">Premium bottles seven nights a week. Full late-night kitchen Friday through Sunday, with pizza and mozzarella sticks available every night.</p>
  </div>

  <section style="padding-bottom:0;">
    <div class="inner-sm" style="text-align:center;">
      <figure style="margin:0 auto;max-width:440px;">
        <img
          src="/images/heather-bartender.jpg"
          alt="Heather, bartender at Just Enuff Cabaret, pouring bottle service in Rockford, IL"
          width="1000" height="1250" loading="lazy"
          style="width:100%;height:auto;display:block;border-radius:8px;border:1px solid rgba(201,168,76,0.35);"
        />
        <figcaption style="margin-top:0.9rem;font-family:'Playfair Display',serif;color:var(--gold-light);font-size:1.2rem;">
          Heather
          <span style="font-family:'Bebas Neue',sans-serif;letter-spacing:0.14em;color:var(--grey);font-size:0.82rem;">&nbsp;&middot;&nbsp; Bartender</span>
        </figcaption>
      </figure>
    </div>
  </section>

  {happyHour && (
    <section style="padding-top:0;">
      <div class="inner-sm">
        <div style="border:1px solid var(--gold);border-radius:8px;padding:2rem 1.4rem;text-align:center;background:linear-gradient(180deg,rgba(200,16,46,0.12),rgba(201,168,76,0.06));">
          <span class="eyebrow" style="color:var(--gold-light);">Weekday Happy Hour</span>
          <h2 class="section-title" style="margin:0.3rem 0 0.2rem;font-size:1.7rem;">{happyHour.days} · <em style="white-space:nowrap;">{happyHour.time}</em></h2>
          <div class="rule"></div>
          <div class="grid-4" style="margin-top:1.4rem;">
            {happyHour.items.map((it) => (
              <div>
                <div style="font-family:'Bebas Neue',sans-serif;letter-spacing:0.04em;color:var(--gold-light);font-size:2.1rem;line-height:1;">{it.price}</div>
                <div style="font-family:'Playfair Display',serif;color:var(--cream);font-size:1rem;margin-top:0.3rem;">{it.name}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <section>
    <div class="inner-sm">
      <div class="section-header">
        <span class="eyebrow">Premium</span>
        <h2 class="section-title">Bottle <em>Service</em></h2>
        <div class="rule"></div>
      </div>
      {bottleMenu.map((cat) => (
        <div class="menu-cat">
          <h3>{cat.category}</h3>
          {cat.items.map((it) => (
            <div class="menu-item">
              <div><span class="mi-name">{it.name}</span></div>
              <span class="mi-price">{it.price}</span>
            </div>
          ))}
        </div>
      ))}
      <p class="menu-fineprint">All bottle service prices include sales tax.</p>
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="inner-sm">
      <div class="section-header">
        <span class="eyebrow">Late-Night Kitchen</span>
        <h2 class="section-title">Food <em>Menu</em></h2>
        <div class="rule"></div>
      </div>
      {foodMenu.map((cat) => (
        <div class="menu-cat">
          <h3>{cat.category}</h3>
          {cat.items.map((it) => (
            <div class="menu-item">
              <div>
                <span class="mi-name">{it.name}</span>
                {it.desc && <div class="mi-desc">{it.desc}</div>}
              </div>
              <span class="mi-price">{it.price}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <section class="cta-band">
    <div class="inner-sm">
      <h2>Reserve VIP Seating with Bottle Service</h2>
      <p>Pair any bottle with a VIP package for the full experience.</p>
      <a class="btn btn-red" href="/vip">VIP Packages</a>
      <a class="btn btn-gold" href={business.phoneHref} style="margin-left:0.8rem;">Call {business.phone}</a>
    </div>
  </section>
</Base>
