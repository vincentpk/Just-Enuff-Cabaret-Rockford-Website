---
import '../styles/global.css';
import { business } from '../data/site.js';

const {
  title,
  description,
  ogImage = '/images/logo.png',
  schema = null // extra page-level JSON-LD (object or array)
} = Astro.props;

// Normalize "/club.html" → "/club" and "/index" → "/" so canonicals match sitemap URLs
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/');
const canonical = new URL(cleanPath, Astro.site).href;
const ogImageAbs = new URL(ogImage, Astro.site).href;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/club', label: 'The Club' },
  { href: '/dancers', label: 'Dancers' },
  { href: '/events', label: 'Events' },
  { href: '/vip', label: 'VIP Packages' },
  { href: '/menu', label: 'Menu' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/faqs', label: 'FAQs' },
  { href: '/contact', label: 'Contact' },
  { href: '/hiring', label: 'Now Hiring' }
];
const path = cleanPath.replace(/\/$/, '') || '/';

// LocalBusiness structured data — on every page
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'NightClub',
  additionalType: 'https://schema.org/AdultEntertainment',
  name: business.name,
  description: business.description,
  slogan: business.tagline,
  url: Astro.site?.href,
  logo: new URL('/images/logo.png', Astro.site).href,
  image: ogImageAbs,
  telephone: business.phone,
  email: business.email,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.state,
    postalCode: business.address.zip,
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: business.geo.lat, longitude: business.geo.lng },
  hasMap: business.mapsUrl,
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '16:00',
    closes: '02:00'
  }],
  areaServed: ['Rockford IL', 'Loves Park IL', 'Machesney Park IL', 'Belvidere IL', 'Rockton IL',
    'Beloit WI', 'Janesville WI', 'Chicago IL', 'Elgin IL', 'Aurora IL', 'DeKalb IL',
    'Lake Geneva WI', 'Madison WI', 'Milwaukee WI'],
  ...(business.socials.length ? { sameAs: business.socials } : {})
};

const schemas = [businessSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/emblem.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="rating" content="adult" />
    <meta name="geo.region" content="US-IL" />
    <meta name="geo.placename" content="Rockford" />
    <meta name="geo.position" content={`${business.geo.lat};${business.geo.lng}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&display=swap"
      rel="stylesheet"
    />

    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <!-- 21+ age gate -->
    <div class="age-gate gone" id="ageGate" aria-hidden="true">
      <img class="age-gate-logo" src="/images/logo.png" alt={`${business.name} logo`} width="220" height="189" />
      <div class="age-gate-title">Are You 21 or Older?</div>
      <div class="age-gate-sub">You must be of legal age to enter this site.</div>
      <div class="age-gate-btns">
        <button class="btn btn-red" id="ageYes">Yes, I am 21+</button>
        <a class="btn btn-gold" href="https://www.google.com">No, Exit</a>
      </div>
      <div class="age-gate-legal">
        By entering you confirm you are 21+ years of age. {business.name} is a licensed adult
        entertainment establishment in {business.address.city}, {business.address.state}.
      </div>
    </div>

    <nav aria-label="Main navigation">
      <a href="/" aria-label={`${business.name} home`}>
        <img class="nav-logo" src="/images/logo.png" alt={`${business.name}, Gentlemen's Club in Rockford, IL`} width="58" height="50" />
      </a>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links" id="navLinks">
        {navLinks.map((l) => (
          <a href={l.href} class={path === l.href ? 'active' : ''} aria-current={path === l.href ? 'page' : undefined}>{l.label}</a>
        ))}
        <a class="nav-book" href={business.phoneHref}>Book Now</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <img class="footer-logo" src="/images/logo.png" alt={`${business.name} logo`} width="81" height="70" loading="lazy" />
      <div class="footer-tag">{business.tagline}.</div>
      <div class="footer-links">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-links" style="margin-top:-0.6rem;">
        {business.socialLinks.map((s) => (
          <a href={s.url} target="_blank" rel="noopener" style="color:var(--gold);">{s.label}</a>
        ))}
      </div>
      <div class="footer-legal">
        <a href={business.mapsUrl} target="_blank" rel="noopener">{business.address.street}, {business.address.city}, {business.address.state} {business.address.zip}</a>
        · <a href={business.phoneHref}>{business.phone}</a> · <a href={`mailto:${business.email}`}>{business.email}</a><br />
        {business.hours}<br />
        🔞 Adults 21+ Only · Must Present Valid ID at Door<br />
        © {new Date().getFullYear()} {business.name}. All Rights Reserved. Rockford, IL. Proudly serving
        guests from Chicago, Elgin, Aurora, Beloit, Janesville, Lake Geneva, Madison &amp; Milwaukee.
      </div>
    </footer>

    <script>
      // Age gate (remembered for 30 days)
      const gate = document.getElementById('ageGate');
      const KEY = 'jec_age_ok';
      let ok = false;
      try {
        const saved = JSON.parse(localStorage.getItem(KEY) || 'null');
        ok = saved && Date.now() - saved.t < 30 * 24 * 60 * 60 * 1000;
      } catch {}
      if (!ok) {
        gate.classList.remove('gone');
        gate.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      document.getElementById('ageYes').addEventListener('click', () => {
        try { localStorage.setItem(KEY, JSON.stringify({ t: Date.now() })); } catch {}
        gate.classList.add('gone');
        gate.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });

      // Mobile nav
      const burger = document.getElementById('hamburger');
      const links = document.getElementById('navLinks');
      burger.addEventListener('click', () => {
        const open = links.classList.toggle('open');
        burger.classList.toggle('open', open);
        burger.setAttribute('aria-expanded', String(open));
      });
    </script>
  </body>
</html>
