---
import '../styles/global.css';
import { business } from '../data/site.js';

const {
  title,
  description,
  ogImage = '/images/og-image.jpg', // 1200x630 link-preview card (iMessage, Facebook, etc.)
  schema = null // extra page-level JSON-LD (object or array)
} = Astro.props;

// Normalize "/club.html" → "/club" and "/index" → "/" so canonicals match sitemap URLs
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/');
const canonical = new URL(cleanPath, Astro.site).href;
const ogImageAbs = new URL(ogImage, Astro.site).href;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/club', label: 'The Club' },
  { href: '/dancers', label: 'Dancers' },
  { href: '/events', label: 'Events' },
  { href: '/vip', label: 'VIP Packages' },
  { href: '/menu', label: 'Menu' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/faqs', label: 'FAQs' },
  { href: '/contact', label: 'Contact' },
  { href: '/apply', label: 'Apply' }
];
const path = cleanPath.replace(/\/$/, '') || '/';

// LocalBusiness structured data — on every page
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'NightClub',
  additionalType: 'https://schema.org/AdultEntertainment',
  name: business.name,
  description: business.description,
  slogan: business.tagline,
  url: Astro.site?.href,
  logo: new URL('/images/logo.png', Astro.site).href,
  image: ogImageAbs,
  telephone: business.phone,
  email: business.email,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.state,
    postalCode: business.address.zip,
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: business.geo.lat, longitude: business.geo.lng },
  hasMap: business.mapsUrl,
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '16:00',
    closes: '02:00'
  }],
  areaServed: ['Rockford IL', 'Loves Park IL', 'Machesney Park IL', 'Belvidere IL', 'Rockton IL',
    'Beloit WI', 'Janesville WI', 'Chicago IL', 'Elgin IL', 'Aurora IL', 'DeKalb IL',
    'Lake Geneva WI', 'Madison WI', 'Milwaukee WI'],
  ...(business.socials.length ? { sameAs: business.socials } : {})
};

const schemas = [businessSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];

// Official brand glyphs (simple-icons paths, 24x24 viewBox)
const socialIcons = {
